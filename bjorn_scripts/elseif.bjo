#use "libraries/user_libs/bstdio.bjo"




func void main(uint8 x)
{
    uint8 x = 11;
    uint8 y = 10;

    if (x > 15)
    {
        print("Fell A\n");
        y = 1;
    }
    elseif (x < 2)
    {
        print("Fell B\n");
        y = 2;
    }
    elseif (x > 10)
    {
        print("Fell C\n");
        y = 100;
    }
    else 
    {
        print("Fell D\n");
        y = 4;
    }

    print(y);
}