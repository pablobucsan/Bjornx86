#use "libraries/user_libs/bstdio.bjo"



object A
{
    uint8 field;
};

func void swap(ptr<ptr<A>> a, ptr<ptr<A>> b)
{
    *a = *b;
}


func void main()
{
    A dummy;
    dummy.field = 10;
    A bob;
    bob.field = 20;
    ptr<A> pdummy = &dummy;
    ptr<A> pbob = &bob;
    print(pdummy->field);

    swap(&pdummy, &pbob);

    print(pdummy->field);
}

