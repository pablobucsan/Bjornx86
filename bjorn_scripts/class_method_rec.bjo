#use "libraries/user_libs/bstdio.bjo"


class Math 
{
    func uint32 fib(uint8 n)
    {
        if (n <= 1) { return n; }

        return this->fib(n - 1) + this->fib(n - 2);
    }
}


class Foo extends Math
{
    uint8 x;

    func void d(uint8 n)
    {
        print(this->fib(n));
    }

}

func void main()
{    
    Foo f; f.x = 0xA;
    f.d(f.x);
}