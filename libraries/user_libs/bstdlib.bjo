
// #use "bstdio.bjo"
// null pointer
// points to address 0 -> invalid address
ptr<void> null = (ptr<void>)0;

forward func void printf(str fmt, varargs);
// Memory protection flag bits, choose or or-ed together

uint64 PROT_NONE = 0;   // no permissions
uint64 PROT_READ = 1;   // pages can be read
uint64 PROT_WRITE = 2;  // pages can be written
uint64 PROT_EXEC = 4;   // pages can be executed

// Sharing type for the memory block, choose one
uint64 MAP_SHARED = 1;  // share changes
uint64 MAP_PRIVATE = 2; // changes are private
uint64 MAP_ANONYMOUS = 0x20; // allocated from memory

uint64 PAGE_SIZE = 0x1000; //4096


uint64 __HEADER_SIZE = 32;   // First three fields of __FreeBlock comprehend the header
uint64 __HEAP_HEADER_SIZE = 32; // Fields at the beginning of every heap
uint64 __REQSIZE_OFFSET = 8;
uint64 __TOTSIZE_OFFSET = 16;
uint64 __MAGIC_OFFSET = 24;

uint64 __MAGIC_ALLOCATED = 0xA110CBEEF;  // Magic number to tell whether its been allocated
uint64 __MAGIC_FREED = 0xF3EEDBEEF;     // Magic number to tell whether its been freed
uint64 __MAX_ALIGN_SIZE = 32;

// Exits execution
extern func void exit(int32 code);
// Copies a block of memory
extern func void memcpy(ptr<void> dst, ptr<void> src, uint64 size);

// Allocates 4096B (4KB) of memory with the specified protection and flags
// If flag contains ANONYMOUS, then the fd must be -1 (no file)
extern func ptr<void> mmap(ptr<void> addr, uint64 len, uint64 prot, uint64 flags , uint64 fd, uint64 off);

// Sets the count bytes of memory starting at dst with value
extern func void memset(ptr<void> dst, char value, uint64 count);

object __FreeBlock
{
    ptr<__FreeBlock> p_nextFreeBlock;
    uint64 magic;
    uint64 totalAllocatedBlockSize;
    uint64 requestedSize;
}

object __Heap
{
    ptr<__Heap> p_nextHeap;
    ptr<__FreeBlock> p_firstFreeBlock;
    uint64 usableHeapMemoryLeft;
    uint64 totalHeapMemory;
}

bool __heap_init = false;
ptr<__Heap> __heap;

