func uint64 __align_to(uint64 size, uint64 multiple_of)
{
    uint64 allocating_size = size + (multiple_of - 1) - (multiple_of + size - 1) % multiple_of;
    return allocating_size;
}

func ptr<__FreeBlock> __createFreeBlock(ptr<void> header_start, uint64 allocated_size, ptr<__FreeBlock> next_free)
{
    //printf("Creating a free block with header_start = %p\n", header_start);
    ptr<__FreeBlock> p_freeBlock = header_start;
    p_freeBlock->p_nextFreeBlock = next_free;
    p_freeBlock->requestedSize = 0;
    p_freeBlock->totalAllocatedBlockSize = allocated_size;

    // print("Just created a free block:\n");
    // __displayBlock(p_freeBlock);

    //printf("Returning: %p\n", p_freeBlock);
    return p_freeBlock;
}

func void __mergeFreeBlocks(ptr<__FreeBlock> free_block, ptr<__FreeBlock> coalescent_block)
{
    free_block->p_nextFreeBlock = coalescent_block->p_nextFreeBlock;
    free_block->totalAllocatedBlockSize += coalescent_block->totalAllocatedBlockSize;
}

func void __tryMergeFreeBlocks(ptr<__FreeBlock> prev_block, ptr<__FreeBlock> free_block)
{
    // 1. Try to merge with next block
    if (free_block->p_nextFreeBlock != null && free_block + free_block->totalAllocatedBlockSize == free_block->p_nextFreeBlock){
        __mergeFreeBlocks(free_block, free_block->p_nextFreeBlock);
    }

    // 2. Try to merge with previous
    if (prev_block != null && prev_block + prev_block->totalAllocatedBlockSize == free_block){
        __mergeFreeBlocks(prev_block, free_block);
    }
}


