func ptr<__Heap> __createNewHeap(uint64 size_guess, ptr<__Heap> next_heap)
{
    //print("$$$$ CREATING A HEAP $$$$ \n");

    // We need enough size for the heap header + the size guess
    uint64 needed_size = size_guess + __HEAP_HEADER_SIZE;
    // The OS already aligns size_guess to a multiple of PAGE_SIZE
    ptr<__Heap> new_heap = mmap(null, needed_size, PROT_READ | PROT_WRITE, MAP_PRIVATE | MAP_ANONYMOUS, (uint64)-1, (uint64)0);
    new_heap->totalHeapMemory = __align_to(needed_size, PAGE_SIZE);
    new_heap->usableHeapMemoryLeft = new_heap->totalHeapMemory - sizeof(__Heap);
    new_heap->p_firstFreeBlock = __createFreeBlock(new_heap + sizeof(__Heap), new_heap->usableHeapMemoryLeft, null);
    //printf("new_heap->p_firstFreeBlock = %p\n", new_heap->p_firstFreeBlock);
    new_heap->p_nextHeap = next_heap;

    //__displayHeap(new_heap);


    return new_heap;
}

// TODO: Initital heap memory may be more than 4096
func void __initHeap(uint64 size){

    __heap = __createNewHeap(size, null);
    __heap_init = true;


}

// WIP
func ptr<void> malloc(uint64 requested_size){
    // Align to a multiple of __MAX_ALIGN_SIZE so the pointer is aligned to the max alignment required by any built-in type (8 in this case for ptr<T>)
    uint64 allocating_size = __align_to(requested_size + __HEADER_SIZE, __MAX_ALIGN_SIZE);

    // printf("----- ALLOCATING: %lu -------- \n", allocating_size);
    //displayHeaps();

    // Init the first heap if not done yet
    if (__heap_init == false){
        __initHeap(allocating_size);

    }

    //printf("heap = %p\n", __heap);
    // Get the heap owning the total space mapped containing enough memory for the requested_size
    // Start with the first requested heap
    ptr<__Heap> prev_heap = null;
    ptr<__Heap> heap_to_use = __heap;

    // printf("Allocating: %lu\n", allocating_size);
    // printf("Current heap usable space left: %lu\n", heap_to_use->usableHeapMemoryLeft);
    // __displayBlock(heap_to_use->p_firstFreeBlock);

    while (heap_to_use != null && allocating_size >= heap_to_use->usableHeapMemoryLeft){
        prev_heap = heap_to_use;
        heap_to_use = heap_to_use->p_nextHeap;
        
    }
    //printf("heap_to_use = %p\n", heap_to_use);

    // Couldnt find an already mapped heap big enough to hold the allocation
    if (heap_to_use == null){
        // Create a new heap
        ptr<__Heap> new_heap = __createNewHeap(allocating_size, null);
        // If we couldnt request more memory
        if (new_heap == null){
            return null;
        }
        //Link it on the chain
        prev_heap->p_nextHeap = new_heap;
        // We will use this new heap
        heap_to_use = new_heap;

        //printf("We got a new heap\n");
    }

    // From now on, we use heap_to_use
    ptr<__FreeBlock> p_previousCurrentFreeBlock = null;
    ptr<__FreeBlock> p_currentFreeBlock = heap_to_use->p_firstFreeBlock;


    while (p_currentFreeBlock != null){
        // print("MALLOC iteration. Starting with block at: ");
        // print(p_currentFreeBlock);
        // print(",current alloc size: ");
        // print(p_currentFreeBlock->totalAllocatedBlockSize);
        // print(", allocating size needed: ");
        // print(allocating_size);
        // putc('\n');

        //printf("MALLOC iteration. Prev block: %p. Current block: %p, with total alloc size: %lu\n", p_previousCurrentFreeBlock, p_currentFreeBlock, p_currentFreeBlock->totalAllocatedBlockSize);

        // If the block is just enough for the allocation, remove it from the chain and update its header info
        if (p_currentFreeBlock->totalAllocatedBlockSize == allocating_size){
            //printf("Got in exact case\n");

            // Update header info
            p_currentFreeBlock->magic = __MAGIC_ALLOCATED;
            p_currentFreeBlock->requestedSize = requested_size;
            
            // Remove from chain
            if (p_previousCurrentFreeBlock == null){
                heap_to_use->p_firstFreeBlock = p_currentFreeBlock->p_nextFreeBlock;
            }
            else{
                p_previousCurrentFreeBlock->p_nextFreeBlock = p_currentFreeBlock->p_nextFreeBlock;
            }
            // Decrement total usable memory left
            heap_to_use->usableHeapMemoryLeft -= allocating_size;
            // Return pointer

            //printf("FINISHED MALLOC:\n");
            //displayFreeBlocks();
            //printf("Successful malloc!\n");
            return p_currentFreeBlock + __HEADER_SIZE;
        }

        // If the block is bigger than the allocation needed
        elseif (p_currentFreeBlock->totalAllocatedBlockSize > allocating_size){
            //printf("--- GOT IN BIGGER CASE ---- \n");
            // Save the pointer to the writable memory
            ptr<void> p_result = p_currentFreeBlock + __HEADER_SIZE;
            uint64 total_alloc_size = p_currentFreeBlock->totalAllocatedBlockSize;
            //printf("TOT ALLOC SIZE OF BLOCK: %lu\n",total_alloc_size );

            // Update the meta info 
            p_currentFreeBlock->magic = __MAGIC_ALLOCATED;
            p_currentFreeBlock->requestedSize = requested_size;
            p_currentFreeBlock->totalAllocatedBlockSize = allocating_size;

            // If there is space left for a new block 
            if (total_alloc_size - allocating_size >= __HEADER_SIZE + __MAX_ALIGN_SIZE){
                //printf("SPLITTING A NEW BLOCK\n");
                // New block at a new position
                p_currentFreeBlock = __createFreeBlock(p_currentFreeBlock + allocating_size, 
                                                    total_alloc_size - allocating_size, p_currentFreeBlock->p_nextFreeBlock);

                // This is the new free block at this position
                if (p_previousCurrentFreeBlock == null){
                    heap_to_use->p_firstFreeBlock = p_currentFreeBlock;
                }
                else{
                    p_previousCurrentFreeBlock->p_nextFreeBlock = p_currentFreeBlock;
                }
                // Only subtract the allocating size, the exceeding is part of the new free block
                heap_to_use->usableHeapMemoryLeft -= allocating_size;
            }

            // Not enough space for a new block, just remove this one from the chain
            else{
                if (p_previousCurrentFreeBlock == null){
                    heap_to_use->p_firstFreeBlock = p_currentFreeBlock->p_nextFreeBlock;
                }
                else{
                    p_previousCurrentFreeBlock->p_nextFreeBlock = p_currentFreeBlock->p_nextFreeBlock;
                }
                // Subtract the entire thing, (total_alloc_size - allocating_size) is not big enough for a new block
                heap_to_use->usableHeapMemoryLeft -= total_alloc_size;
            }

            //printf("Successful malloc!\n");
            return p_result;
        }

        // Move on to the next block
        p_previousCurrentFreeBlock = p_currentFreeBlock;
        p_currentFreeBlock = p_currentFreeBlock->p_nextFreeBlock;

        // No more space in the current heap
        if (p_currentFreeBlock == null){
            // Search another heap onward
            prev_heap = heap_to_use;
            ptr<__Heap> next_heap = heap_to_use->p_nextHeap;
            while (next_heap != null && allocating_size >= next_heap->usableHeapMemoryLeft){
                //printf("MEMORY FRAGMENTED, ENOUGH SPACE IN CURRENT HEAP BUT CANT RETRIEVE. MOVING ONTO ANOTHER HEAP\n");
                prev_heap = next_heap;
                next_heap = next_heap->p_nextHeap;
            }

            // No heap can satisfy the request besides the one found at the beginning, but that one is fragmented
            // Try to create a new heap
            if (next_heap == null){
                // Create a new heap
                ptr<__Heap> new_heap = __createNewHeap(allocating_size, null);
                // If we couldnt request more memory
                if (new_heap == null){
                    return null;
                }
                //Link it on the chain
                prev_heap->p_nextHeap = new_heap;
                // We will use this new heap
                next_heap = new_heap;
            }

            heap_to_use = next_heap;
            // Set the variables to start looping the heap's free blocks
            p_previousCurrentFreeBlock = null;
            p_currentFreeBlock = heap_to_use->p_firstFreeBlock;

            //printf("############ GOT IN HERE, current block: %p ########## \n", p_currentFreeBlock);
            //displayHeaps();
        }
    }
    //printf("Returning null from malloc()\n");
    return null;
}

// WIP
func void free(ptr<void> p)
{
    if (p == null){
        return;
    }

    uint64 requested_size = (uint64)*(p - __REQSIZE_OFFSET);
    uint64 total_allocated_block_size = (uint64)*(p - __TOTSIZE_OFFSET);
    uint64 magic = (uint64)*(p - __MAGIC_OFFSET);
    if (magic == __MAGIC_FREED){
        printf("Double free detected\n");
        // print(p);
        // putc('\n');
        exit((int32)1);
    }

    // Find what heap we are freeing from. If heap_start + heap_size < p, then p does not belong to that heap
    // Start from the first one
    ptr<__Heap> heap_to_use = __heap;
    while ( !(heap_to_use < p && heap_to_use + heap_to_use->totalHeapMemory > p) ){
        heap_to_use = heap_to_use->p_nextHeap;
    }


    // Find in what position of the chain this new free block would go
    ptr<__FreeBlock> p_previousCurrentFreeBlock = null;
    ptr<__FreeBlock> p_currentFreeBlock = heap_to_use->p_firstFreeBlock;

    while (p_currentFreeBlock != null && p_currentFreeBlock + __HEADER_SIZE < p){
        p_previousCurrentFreeBlock = p_currentFreeBlock;
        p_currentFreeBlock = p_currentFreeBlock->p_nextFreeBlock;
    }

    // Insert the new free block at its correct position, the previous free block points to this new one, and this new one points to the next one in the chain
    ptr<__FreeBlock> p_newFreedBlock = __createFreeBlock(p - __HEADER_SIZE, total_allocated_block_size, p_currentFreeBlock);
    if (p_previousCurrentFreeBlock == null){
        heap_to_use->p_firstFreeBlock = p_newFreedBlock;
    }
    else{
        p_previousCurrentFreeBlock->p_nextFreeBlock = p_newFreedBlock;
    }

    // Potentially merge free blocks. 
    // If the start of the new freed block header, plus the header size, plus the block size equals the start of the header of the next free block, merge them
    __tryMergeFreeBlocks(p_previousCurrentFreeBlock, p_newFreedBlock);

    ptr<__FreeBlock> pf = p - __HEADER_SIZE;
    pf->magic = __MAGIC_FREED;

    // Increment the heap usable memory
    heap_to_use->usableHeapMemoryLeft += total_allocated_block_size;
}

func ptr<void> __reallocShrink(ptr<void> p, uint64 new_size)
{
    //printf("reallocShrink()\n");
    uint64 total_allocated_block_size = (uint64)*(p - __TOTSIZE_OFFSET);
    uint64 writable_memory_size = total_allocated_block_size - __HEADER_SIZE;
    uint64 new_total_alloc_size = __align_to(new_size + __HEADER_SIZE, __MAX_ALIGN_SIZE);


    // Find what heap we are using. If heap_start + heap_size < p, then p does not belong to that heap
    // Start from the first one
    ptr<__Heap> heap_to_use = __heap;
    while ( !(heap_to_use < p && heap_to_use + heap_to_use->totalHeapMemory > p) ){
        heap_to_use = heap_to_use->p_nextHeap;
    }

    // If writable_memory_size - new_size is big enough to hold a header and at least 32 bytes of payload, we create a new free block
    if (writable_memory_size - new_size >= __HEADER_SIZE + __MAX_ALIGN_SIZE){
        // Find in what position of the chain this new free block would go
        ptr<__FreeBlock> p_previousCurrentFreeBlock = null;
        ptr<__FreeBlock> p_currentFreeBlock = heap_to_use->p_firstFreeBlock;
        while (p_currentFreeBlock != null && p_currentFreeBlock + __HEADER_SIZE < p ){
            p_previousCurrentFreeBlock = p_currentFreeBlock;
            p_currentFreeBlock = p_currentFreeBlock->p_nextFreeBlock;
        }
        // Insert the new free block at its correct position, the previous free block points to this new one, and this new one points to the next one in the chain
        ptr<__FreeBlock> p_newFreedBlock = __createFreeBlock(p + new_total_alloc_size - __HEADER_SIZE, 
                                            total_allocated_block_size -  new_total_alloc_size , p_currentFreeBlock);

        if (p_previousCurrentFreeBlock == null){
            heap_to_use->p_firstFreeBlock = p_newFreedBlock;
        }
        else{
            p_previousCurrentFreeBlock->p_nextFreeBlock = p_newFreedBlock;
        }

        // Potentially merge free blocks. 
        // If the start of the new freed block header, plus the header size, plus the block size equals the start of the header of the next free block, merge them
        __tryMergeFreeBlocks(p_previousCurrentFreeBlock, p_newFreedBlock);

        // Return space to the heap
        heap_to_use->usableHeapMemoryLeft += total_allocated_block_size -  new_total_alloc_size;
    }

    //Update the meta information
    ptr<uint64> p_req_size = p - __REQSIZE_OFFSET;
    ptr<uint64> p_total_allocated_mem = p - __TOTSIZE_OFFSET;
    *p_req_size = new_size;
    *p_total_allocated_mem = new_total_alloc_size;

    //printf("FINISHED REALLOC SHRINK:\n");
    //displayFreeBlocks();

    return p;
}

func ptr<void> __reallocExtendInPlace(ptr<void> p, uint64 new_size)
{
    //printf("reallocExtend()\n");
    uint64 total_allocated_block_size = (uint64)*(p - __TOTSIZE_OFFSET);
    uint64 writable_memory_size = total_allocated_block_size - __HEADER_SIZE;
    uint64 new_total_alloc_size = __align_to(new_size + __HEADER_SIZE, __MAX_ALIGN_SIZE);
    
    ptr<__FreeBlock> p_original = p - __HEADER_SIZE;
    ptr<__FreeBlock> p_coalescent = p + writable_memory_size;


    uint64 new_writable_memory = __align_to(new_size + __HEADER_SIZE, __MAX_ALIGN_SIZE) - __HEADER_SIZE;


    // Find what heap we are using. If heap_start + heap_size < p, then p does not belong to that heap
    // Start from the first one
    ptr<__Heap> heap_to_use = __heap;
    while ( !(heap_to_use < p && heap_to_use + heap_to_use->totalHeapMemory > p) ){
        heap_to_use = heap_to_use->p_nextHeap;
    }

    // UNLINK p_coalescent FIRST
    ptr<__FreeBlock> prev = null;
    ptr<__FreeBlock> curr = heap_to_use->p_firstFreeBlock;
    while (curr != null && curr != p_coalescent) {
        prev = curr;
        curr = curr->p_nextFreeBlock;
    }

    if (curr == null) {
        //print("ERROR: coalescent not found in free list\n");
        exit((int32)1);
    }
    // Unlink
    if (prev == null) {
        heap_to_use->p_firstFreeBlock = p_coalescent->p_nextFreeBlock;
    } 
    else {
        prev->p_nextFreeBlock = p_coalescent->p_nextFreeBlock;
    }

    uint64 old_total_allocated_original_size = p_original->totalAllocatedBlockSize;
    uint64 excess = p_coalescent->totalAllocatedBlockSize - (new_writable_memory - writable_memory_size);

    // Is there enough space to split a new free block
    if (excess >= __HEADER_SIZE + __MAX_ALIGN_SIZE){
        ptr<__FreeBlock> p_newFreeBlock = __createFreeBlock(p_original + new_total_alloc_size, 
                                                            excess, 
                                                            p_coalescent->p_nextFreeBlock);
        // Insert the new block in the chain
        if (prev == null) {
            heap_to_use->p_firstFreeBlock = p_newFreeBlock;
        } 
        else {
            prev->p_nextFreeBlock = p_newFreeBlock;
        }
    }

    p_original->totalAllocatedBlockSize = new_total_alloc_size;
    p_original->requestedSize = new_size;

    // Substract from heap total usable memory
    heap_to_use->usableHeapMemoryLeft -= new_total_alloc_size - total_allocated_block_size;
    //printf("FINISHED REALLOC EXTEND:\n");
    //displayFreeBlocks();
    // Return the same pointer
    return p;
}

func ptr<void> realloc(ptr<void> p, uint64 new_size)
{  

    //printf("Calling realloc\n");
    // Cannot reallocate a freed pointer
    uint64 magic = (uint64)*(p - __MAGIC_OFFSET);
    if (magic == __MAGIC_FREED){
        // print("ERROR: Can't realloc a freed pointer: ");
        // print(p);
        // putc('\n');
        exit((int32)1);
    }
    // realloc(null, new_size) = malloc(new_size)
    if (p == null){
        return malloc(new_size);
    }
    // realloc(p, 0) = free(p);
    if (new_size == 0){
        free(p);
        return null;
    }


    uint64 total_allocated_block_size = (uint64)*(p - __TOTSIZE_OFFSET);
    uint64 writable_memory_size = total_allocated_block_size - __HEADER_SIZE;
    uint64 new_total_alloc_size = __align_to(new_size + __HEADER_SIZE, __MAX_ALIGN_SIZE);

    //printf("REMALLOC(%lu)\n", new_total_alloc_size);


    // Case 1: There is already enough memory allocated for the block to satisfy new size
    if (new_size < writable_memory_size){
        return __reallocShrink(p, new_size);
    }

    // Case 2: Check if next block is free and together with this one, big enough
    ptr<__FreeBlock> p_original = p - __HEADER_SIZE;
    ptr<__FreeBlock> p_coalescent = p + writable_memory_size;
    //printf("--- CHECKING FOR REALLOC EXTEND --- \n");
    //printf("totBlockSize: %lu, p_coalescent->totBlockSize: %lu, new: %lu\n", total_allocated_block_size, p_coalescent->totalAllocatedBlockSize, new_total_alloc_size);
    if (p_coalescent->magic != __MAGIC_ALLOCATED && 
        total_allocated_block_size + p_coalescent->totalAllocatedBlockSize >= new_total_alloc_size){
        return __reallocExtendInPlace(p, new_size);
    }

    //printf("reallocFallback()\n");
    // Case 3: Fallback to malloc + copy + free
    ptr<void> newp = malloc(new_size);
    memcpy(newp, p, writable_memory_size);
    free(p);
    //printf("FINISHED REALLOC FALLBACK:\n");
    //displayFreeBlocks();
    return newp;
}


func ptr<void> zalloc(uint64 size)
{
    ptr<void> p = malloc(size);
    if (p != null){
        memset(p, (char)0, size);
    }

    return p;
}