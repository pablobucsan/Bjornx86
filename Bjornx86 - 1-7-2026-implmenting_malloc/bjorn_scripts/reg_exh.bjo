#use "libraries/user_libs/bstdio.bjo"


object Bar 
{
    uint16 field;
    uint32 grass;
}

func uint8 foo(uint8 x)
{
    return 1 * x;
}

func void main()
{    

    Bar b;
    b.field = 12;
    b.grass = 12;

    uint8 y = 3;
    uint8 x = 2;
    uint8 z = 4;

    uint8[3] arr = [1,2,3];

    x = x * (b.field / foo(z / arr[1]) + (b.grass * x * (z / x) )/ (y * 2));


    print(x);
    
}
