
#use "libraries/user_libs/bstdio.bjo"



object B 
{
    uint8 dummy;
    uint16[3] arr;
};

object A 
{
    uint8 count;
    uint8[3] arr;
    B b;
};


func void main()
{

    A a;
    a.count = 3;
    a.b.dummy = 15;
    for (uint8 i = 0; i < a.count; i = i + 1)
    {
        a.arr[i] = i;
        a.b.arr[i] = i * i;
        print(a.arr[i]);
        print(a.b.arr[i]);
    }
}


