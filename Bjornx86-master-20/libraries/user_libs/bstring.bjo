

func uint8 cmpstring(str s1, str s2)
{
    // Loop over the chars of the strins
    uint32 i = 0;
    while (s1[i] != '\0' && s2[i] != '\0')
    {
        if (s1[i] != s2[i]) { return 0; }
        i++;
    }

    // If we got here means that either s1[i] == \'0' || s2[i] == '\0'
    // If both are equal to '\0' then return 1, otherwise 0
    return s1[i] == s2[i];
}