func ptr<File> fopen(str filePath, FileOpenFlags flags)
{    

    // Mode
    // FileMode mode = MODE666;
    // printf("Opening file: '%s' with flags= %hx,  mode=%hx\n", open_flags, m);

    // Open the file 
    int32 fd = open(filePath, (uint64)flags, (uint64)438);
    // printf("Open returned fd = %i\n", fd);

    if (fd < 0){
        return null;
    }

    ptr<File> f = malloc(sizeof(File));
    if (f == null){
        close(fd);
        return null;
    }

    f->fd = fd;
    f->open_flags = flags;
    // f->mode = mode;
    f->filePath = strdup(filePath);

    return f;    
}

func uint32 freadBytes(ptr<File> f, ptr<char> buf, uint32 bytes)
{
    uint32 amount = read(f->fd, buf, bytes);
    return amount;
}

func ptr<char> freadAll(ptr<File> f)
{
    // Initial chunk of 256 that will double if we run out of space
    uint32 buf_size = 256;
    bool keep_reading = true;
    uint32 index = 0;
    ptr<char> buf = malloc((uint64)buf_size);

    while (keep_reading){
        // Always have space for one more buf_size
        if (index + buf_size >= buf_size * 2){
            buf_size = buf_size * 2;
            buf = realloc(buf, (uint64)buf_size);
        }
        uint32 bytes_read = freadBytes(f, &buf[index], buf_size - index);
        if (bytes_read < buf_size - index){
            keep_reading = false;
        }
        index += bytes_read;

    }
    buf = realloc(buf, (uint64)index + 1);

    buf[index] = '\0';
    return buf;  
}

func char fgetc(ptr<File> f)
{
    char result = 0;
    uint32 amount = read(f->fd, &result, (uint32)1);
    if (amount == 0){
        return EOF;
    }
    return result;
}

func void fclose(ptr<File> f)
{
    close(f->fd);
}

func int32 makeDirectory(str pathname, FileMode mode)
{
    int32 result = mkdir(pathname, (uint64)mode);
    return result;
}


// Function to print a char to file
func void fprint(ptr<File> f, char c)
{
    fputc(f->fd, c);
}

func void fprint(ptr<File> f, str s)
{
    uint64 i = 0;
    while (s[i] != '\0'){
        fputc(f->fd, s[i++]);  
    }

}

func void fprint(ptr<File> f, bool b)
{
    if (b){
        fprint(f, "true");
    }
    else{
        fprint(f, "false");
    }
}

func void fprint(ptr<File> f, uint8 x)
{
    if (x == 0){
        fputc(f->fd, '0');
        return;
    }
    // 3 digits max + '\0'
    char[4] buffer;
    int8 index = 3;
    buffer[index] = '\0';
    while (x > 0){
        index--;
        buffer[index] = (char)(x % 10) + '0';
        x = x / 10;
    }
    fprint(f, &buffer[index]);
}

func void fprint(ptr<File> f, int8 x)
{
    if (x < 0){
        fputc(f->fd, '-');
        x = -x;
    }

    fprint(f, (uint8)x);
}

func void fprint(ptr<File> f, uint16 x)
{
    if (x == 0){
        fputc(f->fd, '0');
        return;
    }
    // 5 digits max + '\0'
    char[6] buffer;
    int8 index = 5;
    buffer[index] = '\0';

    while (x > 0){
        index--;
        buffer[index] = (char)(x % 10) + '0';
        x = x / 10;
    }
    fprint(f, &buffer[index]);
}

func void fprint(ptr<File> f, int16 x)
{
    if (x < 0)
    {
        fputc(f->fd, '-');
        x = -x;
    }

    fprint(f, (uint16)x);
}


func void fprint(ptr<File> f, uint32 x)
{
    if (x == 0){
        fputc(f->fd, '0');
        return;
    }
    // 10 digit max + '\0'
    char[11] buffer;
    int8 index = 10;
    buffer[index] = '\0';

    while (x > 0){
        index--;
        buffer[index] = (char)(x % 10) + '0';
        x = x / 10;
    }
    fprint(f, &buffer[index]);
}

func void fprint(ptr<File> f, int32 x)
{
    if (x < 0){
        fputc(f->fd, '-');
        x = -x;
    }
    fprint(f, (uint32)x);
}


func void fprint(ptr<File> f, uint64 x)
{
    if (x == 0) {
        fputc(f->fd, '0');
        return;
    }

    char[21] buffer;
    int8 index = 20;
    buffer[index] = '\0';  // null terminator at end
    
    while (x > 0) {
        index--;
        buffer[index] = (char)(x % 10) + '0';
        x = x / 10;
    }
    fprint(f, &buffer[index]);
}

func void fprint(ptr<File> f, int64 x)
{
    if (x < 0){
        fputc(f->fd, '-');
        x = -x;
    }
    fprint(f, (uint64)x);
}


// Printing hexadecimal

func void fprintHex(ptr<File> f, uint64 x)
{
    uint8 mask = 0xF; 
    int8 digits = digitsof(x,16);
    for (int8 i = digits - 1; i >= 0; i--){
        uint8 value = (uint8) ((x >> 4 * i) & mask);
        if (value > 9){
            char c = 'A' + (value - 10);
            fprint(f,c);
        }
        else {
            fprint(f,value);
        }
    }
}


func void fprint(ptr<File> f, ptr<void> p)
{
    uint64 y = (uint64)p;
    fprintHex(f, y);
}


func void fprintf(ptr<File> f, str s, varargs)
{
    uint64 varg_count = 0;
    uint64 str_len = 0;
    for (uint64 i = 0; s[i] != '\0'; i++){
        if (s[i] == '%'){
            varg_count++;
        }
        str_len++;
    }

    ptr<void> curr = varg_start(varg_count);
    uint64 i = 0;
    while (s[i] != '\0' && i < str_len){
        if (s[i] == '%'){
            i++;
            // Case uint8,int8,uint16,int16
            if (s[i] == 'h'){
                i++;
                // Case uint8,int8, hex 8 bits
                if (s[i] == 'h'){
                    i++;
                    // Case uint8
                    if (s[i] == 'u'){
                        i++;
                        fprint(f, *(ptr<uint8>)curr);
                        curr = varg_next(curr);
                    }
                    // Case int8
                    elseif (s[i] == 'i'){
                        i++;
                        fprint(f, *(ptr<int8>)curr);
                        curr = varg_next(curr);
                    }
                    // Case hex
                    elseif (s[i] == 'x'){
                        i++;
                        fprintHex(f, *(ptr<uint8>)curr);
                        curr = varg_next(curr);
                    }
                }
                // Case uint16 
                elseif(s[i] == 'u'){
                    i++;
                    fprint(f, *(ptr<uint16>)curr);
                    curr = varg_next(curr);
                }
                // Case int16
                elseif(s[i] == 'i'){
                    i++;
                    fprint(f, *(ptr<int16>)curr);
                    curr = varg_next(curr);
                }
                // Case hex 16 bits
                elseif (s[i] == 'x'){
                    i++;
                    fprintHex(f, *(ptr<uint16>)curr);
                    curr = varg_next(curr);
                }
            }

            // Case uint32
            elseif (s[i] == 'u'){
                i++;
                fprint(f, *(ptr<uint32>)curr);
                curr = varg_next(curr);
            }
            // Case int32
            elseif (s[i] == 'i'){
                i++;
                fprint(f, *(ptr<int32>)curr);
                curr = varg_next(curr);
            }
            // Case hex 32 bits
            elseif (s[i] == 'x'){
                i++;
                fprintHex(f, *(ptr<uint32>)curr);
                curr = varg_next(curr);
            }

            // Case uint64, int64
            elseif (s[i] == 'l'){
                i++;
                // Case uint64
                if (s[i] == 'u'){
                    i++;
                    fprint(f, *(ptr<uint64>)curr);
                    curr = varg_next(curr);
                }
                // Case int64
                if (s[i] == 'i'){
                    i++;
                    fprint(f, *(ptr<int64>)curr);
                    curr = varg_next(curr);
                }
                // Case hex 64 bits 
                if (s[i] == 'x'){
                    i++;
                    fprintHex(f, *(ptr<uint64>)curr);
                    curr = varg_next(curr);
                }
            }

            // string
            elseif (s[i] == 's'){
                i++;
                str st = *(ptr<str>)curr;
                fprint(f, st);
                curr = varg_next(curr);
            }
            // char
            elseif (s[i] == 'c'){
                i++;
                fprint(f, *(ptr<char>)curr);
                curr = varg_next(curr);
            }
            // boolean
            elseif (s[i] == 'B'){
                i++;
                fprint(f, *(ptr<bool>)curr);
                curr = varg_next(curr);
            }
            // pointer
            elseif (s[i] == 'p'){
                i++;
                ptr<void> address = (ptr<void>)(*(ptr<uint64>)curr);
                fprint(f, address);
                curr = varg_next(curr);
            }
            // hex
            elseif (s[i] == 'x'){
                i++;

            }
        }
        else{
            fputc(f->fd, s[i]);
            i++;
        }
    }
}


