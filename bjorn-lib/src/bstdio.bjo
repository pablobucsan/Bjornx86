// ------------------------------------  WRITING/PRINTING TO STDOUT -------------------------------------------------

func void printf(str s, varargs)
{
    uint64 varg_count = 0;
    uint64 str_len = 0;
    for (uint64 i = 0; s[i] != '\0'; i++){
        if (s[i] == '%'){
            varg_count++;
        }
        str_len++;
    }

    ptr<void> curr = varg_start(varg_count);
    uint64 i = 0;
    while (s[i] != '\0' && i < str_len){
        if (s[i] == '%'){
            i++;
            // Case uint8,int8,uint16,int16
            if (s[i] == 'h'){
                i++;
                // Case uint8,int8
                if (s[i] == 'h'){
                    i++;
                    // Case uint8
                    if (s[i] == 'u'){
                        i++;
                        fprint(STDOUT, *(ptr<uint8>)curr);
                        curr = varg_next(curr);
                    }
                    // Case int8
                    elseif (s[i] == 'i'){
                        i++;
                        fprint(STDOUT, *(ptr<int8>)curr);
                        curr = varg_next(curr);
                    }
                    // Case hex 8 bits
                    elseif (s[i] == 'x'){
                        i++;
                        fprintHex(STDOUT, *(ptr<uint8>)curr);
                        curr = varg_next(curr);
                    }
                }
                // Case uint16 
                elseif(s[i] == 'u'){
                    i++;
                    fprint(STDOUT, *(ptr<uint16>)curr);
                    curr = varg_next(curr);
                }
                // Case int16
                elseif(s[i] == 'i'){
                    i++;
                    fprint(STDOUT, *(ptr<int16>)curr);
                    curr = varg_next(curr);
                }
                // Case hex 16 bits
                elseif (s[i] == 'x'){
                    i++;
                    fprintHex(STDOUT, *(ptr<uint16>)curr);
                    curr = varg_next(curr);
                }
            }

            // Case uint32
            elseif (s[i] == 'u'){
                i++;
                fprint(STDOUT, *(ptr<uint32>)curr);
                curr = varg_next(curr);
            }
            // Case int32
            elseif (s[i] == 'i'){
                i++;
                fprint(STDOUT, *(ptr<int32>)curr);
                curr = varg_next(curr);
            }
            // Case hex 32 bits
            elseif (s[i] == 'x'){
                i++;
                fprintHex(STDOUT, *(ptr<uint32>)curr);
                curr = varg_next(curr);
            }
            // Case uint64, int64
            elseif (s[i] == 'l'){
                i++;
                // Case uint64
                if (s[i] == 'u'){
                    i++;
                    fprint(STDOUT, *(ptr<uint64>)curr);
                    curr = varg_next(curr);
                }
                // Case int64
                elseif (s[i] == 'i'){
                    i++;
                    fprint(STDOUT, *(ptr<int64>)curr);
                    curr = varg_next(curr);
                }

                elseif (s[i] == 'x'){
                    i++;
                    fprintHex(STDOUT, *(ptr<uint64>)curr);
                    curr = varg_next(curr);
                }
            }

            // string
            elseif (s[i] == 's'){
                i++;
                str st = *(ptr<str>)curr;
                fprint(STDOUT, st);
                curr = varg_next(curr);
            }
            // char
            elseif (s[i] == 'c'){
                i++;
                fprint(STDOUT, *(ptr<char>)curr);
                curr = varg_next(curr);
            }
            // boolean
            elseif (s[i] == 'B'){
                i++;
                fprint(STDOUT, *(ptr<bool>)curr);
                curr = varg_next(curr);
            }
            // pointer
            elseif (s[i] == 'p'){
                i++;
                ptr<void> address = (ptr<void>)*(ptr<uint64>)curr;
                fprint(STDOUT, address);
                curr = varg_next(curr);
            }
        }
        else{
            fputc((int32)1, s[i]);
            i++;
        }
    }
}


